# Resend API key — get one at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email address that receives contact form submissions
CONTACT_TO_EMAIL=hello@yourdomain.com

# Sender address (must be from a verified domain in Resend)
CONTACT_FROM_EMAIL=Portfolio Contact <hello@yourdomain.com>

# Public site URL for Open Graph metadata (set to your production domain)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Supabase — from Cursor MCP / Supabase dashboard (Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxx
